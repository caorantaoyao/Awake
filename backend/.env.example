APP_NAME=Awaken MVP
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./awaken.db
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=10080
AUTH_LEGACY_USER_DEFAULT_PASSWORD=change-this-before-running-legacy-migration

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM=your-email@qq.com
SMTP_ENABLED=false

FEISHU_WEBHOOK_REGISTER=https://open.feishu.cn/...
FEISHU_WEBHOOK_TASK_COMPLETE=https://open.feishu.cn/...
FEISHU_ENABLED=false

DEERFLOW_ENABLED=false
DEERFLOW_BASE_URL=http://localhost:8001
DEERFLOW_ASSISTANT_ID=lead_agent
DEERFLOW_API_KEY=
# DeerFlow 控制台接口超时（秒），用于 status/skills/models/skill 开关
DEERFLOW_CONTROL_TIMEOUT_SECONDS=60

FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
