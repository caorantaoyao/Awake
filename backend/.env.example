APP_NAME=Awaken MVP
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./awaken.db

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM=your-email@qq.com
SMTP_ENABLED=false

FEISHU_WEBHOOK_REGISTER=https://open.feishu.cn/...
FEISHU_WEBHOOK_TASK_COMPLETE=https://open.feishu.cn/...
FEISHU_ENABLED=false

DEERFLOW_ENABLED=false
DEERFLOW_BASE_URL=http://localhost:8001
DEERFLOW_ASSISTANT_ID=lead_agent
DEERFLOW_API_KEY=

FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
