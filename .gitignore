# deer-flow 作为 git submodule 纳入版本控制（根目录追踪 commit hash）
# 以下排除 deer-flow 的本地配置、虚拟环境、运行产物
/deer-flow/.env
/deer-flow/backend/.venv/
/deer-flow/.venv/
/deer-flow/frontend/node_modules/
/deer-flow/backend/.deer-flow/
/deer-flow/config.yaml
/deer-flow/extensions_config.json
/deer-flow/conf.yaml

# 依赖与虚拟环境
backend/venv/
frontend/node_modules/
frontend/dist/

# 密钥与本地配置
backend/.env

# 本地数据库与缓存
backend/*.db
backend/.pytest_cache/
**/__pycache__/
*.pyc

# 日志
logs/
*.log

# 测试与自动化产物
output/
.playwright-cli/

# 本地工具缓存与生成内容
.superpowers/
.trae/deepwiki/

# IDE/OS
.DS_Store
.idea/
.vscode/
